# ----------------------------------------------------------------------------
# PixelForge backend — environment configuration
# Copy this file to `.env` and fill in real values before running the server.
#   cp .env.example .env
# ----------------------------------------------------------------------------

# --- Database (MySQL / MariaDB) ---------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pixelforge

# --- HTTP server -------------------------------------------------------------
PORT=3000

# --- Sessions ----------------------------------------------------------------
# Secret used to sign the express-session cookie.
# Use a long, random string in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-to-a-long-random-string

# --- Admin bootstrap (optional) ----------------------------------------------
# Plaintext password for the seeded `admin` staff account. It is bcrypt-hashed
# by `npm run db:setup` and never stored in the DB in clear text.
# Defaults to `admin123` when unset.
ADMIN_BOOTSTRAP=admin123
